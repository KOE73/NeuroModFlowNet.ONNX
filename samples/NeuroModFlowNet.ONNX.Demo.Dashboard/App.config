<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="CudaBinPath" value="C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v12.9\bin" />
    <add key="CudnnBinPath" value="C:\cuDNN\9.10.2.21_cuda12\bin" />
    <add key="TrtLibPath" value="C:\TensorRT\TensorRT-10.12.0.36-cuda12.9\lib" />

    <!--
      VideoSource examples:
      - 0, 1, 2: local USB camera index.
      - C:\video\sample.mp4: local video file.
      - rtsp://host/stream: stream URL without credentials.
      - @VideoSource.local.txt: read the source from an ignored local file.
        Use this form for RTSP URLs with credentials.
    -->
    <add key="VideoSource" value="0" />

    <add key="DashboardBackend" value="Cuda" />
    <add key="DashboardInputSize" value="640" />
    <add key="DashboardPrecision" value="fp32" />
    <add key="DashboardIsByteBgr" value="false" />
    <add key="DashboardEnabledSlots" value="Raw,Box,Obb,Seg,Pose,Cls" />
    <add key="DashboardBoxModelName" value="yolo26n" />
    <add key="DashboardObbModelName" value="yolo26n-obb" />
    <add key="DashboardSegModelName" value="yolo26n-seg" />
    <add key="DashboardPoseModelName" value="yolo26n-pose" />
    <add key="DashboardClsModelName" value="yolo26n-cls" />
  </appSettings>
</configuration>
